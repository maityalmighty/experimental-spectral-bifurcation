   "source": [
    "# Code to vary the parameter (voltage value)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "4ad963ba",
   "metadata": {},
   "outputs": [],
   "source": [
    "import nidaqmx\n",
    "with nidaqmx.Task() as task:    \n",
    "    task.ao_channels.add_ao_voltage_chan(\"myDAQ1/ao0\", min_val = -10.0, max_val = 10)\n",
    "    task.write(-1)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "a2518eea",
   "metadata": {},
   "source": [
    "# Code to vary the parameter within a range (useful to generate bifurcation diagram)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "dc9a885c",
   "metadata": {},
   "outputs": [],
   "source": [
    "import time\n",
    "import numpy as np\n",
    "start = -10\n",
    "end = -0.1\n",
    "step = 0.01  # volts\n",
    "delay = 0.05  # seconds between steps\n",
    "# Generate voltage values\n",
    "voltages = np.arange(start, end + step , step)\n",
    "\n",
    "with nidaqmx.Task() as task:\n",
    "    task.ao_channels.add_ao_voltage_chan(\"myDAQ1/ao0\", min_val= - 10, max_val= 10)\n",
    "    for v in voltages:\n",
    "        task.write(v)\n",
    "        print(f\"Output voltage: {v:.5f} V\")\n",
    "        time.sleep(delay)\n",
    "print(\"Voltage sweep complete.\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "9a6ac9ec",
   "metadata": {},
   "source": [
    "# Code to record the time series data and save it in a CSV file"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f62c88da",
   "metadata": {},
   "outputs": [],
   "source": [
    "import pandas as pd\n",
    "\n",
    "# Sweep parameters\n",
    "start = -10\n",
    "end = -0.1\n",
    "step = 0.01 # volts\n",
    "delay = 1 # seconds per parameter value\n",
    "sample_rate = 200000  # Hz\n",
    "num_samples = int(sample_rate * delay)\n",
    "\n",
    "# Only store this many samples (2^17 = 131072)\n",
    "retain_samples = 2**17\n",
    "voltages = np.arange(start, end + step , step)  # descending sweep\n",
    "\n",
    "# List to store all records\n",
    "all_data = []\n",
    "\n",
    "# Begin sweep\n",
    "for v in voltages:\n",
    "    print(f\"Setting output voltage: {v:.2f} V\")\n",
    "\n",
    "    # Set output voltage on ao0\n",
    "    with nidaqmx.Task() as out_task:\n",
    "        out_task.ao_channels.add_ao_voltage_chan(\"myDAQ1/ao0\", min_val=-10, max_val=0)\n",
    "        out_task.write(v)\n",
    "        time.sleep(1)\n",
    "\n",
    "    # Acquire data from ai0 (X) and ai1 (Y)\n",
    "    with nidaqmx.Task() as task:\n",
    "        task.ai_channels.add_ai_voltage_chan(\"myDAQ1/ai0\", min_val = -10, max_val = 10)\n",
    "        task.ai_channels.add_ai_voltage_chan(\"myDAQ1/ai1\", min_val = -10, max_val = 10)\n",
    "        task.timing.cfg_samp_clk_timing(rate=sample_rate, samps_per_chan = num_samples)\n",
    "\n",
    "        data = task.read(number_of_samples_per_channel = num_samples, timeout = delay + 1)\n",
    "        x_data, y_data = np.array(data[0]), np.array(data[1])\n",
    "        time_array = np.linspace(0, delay, num_samples)\n",
    "\n",
    "        # Keep only last 2^17 samples\n",
    "        x_data = x_data[-retain_samples:]\n",
    "        y_data = y_data[-retain_samples:]\n",
    "        time_array = time_array[-retain_samples:]\n",
    "\n",
    "        # Create a DataFrame for this parameter value\n",
    "        df = pd.DataFrame({'Parameter': v,'Time(s)': time_array,'X': x_data,'Y': y_data})\n",
    "        all_data.append(df)\n",
    "\n",
    "# Combine all and save to CSV\n",
    "results = pd.concat(all_data, ignore_index=True)\n",
    "# Round Parameter values to 2 decimal places\n",
    "results['Parameter'] = results['Parameter'].round(2)\n",
    "results.to_csv(\"Rossler.csv\", index = False)\n",
    "print(\"Sweep and data logging complete. Saved to 'Rossler.csv'\")\n",
    "results.head()"
   ]
  },
